# OpenClaw Email Channel Plugin Configuration
# Copy this file to .env and fill in your credentials

# IMAP Configuration (for receiving emails)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password-here
IMAP_TLS=true
IMAP_AUTH_TIMEOUT=3000
IMAP_CONN_TIMEOUT=10000

# SMTP Configuration (for sending emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=false

# Plugin Settings
EMAIL_ADDRESS=your-email@gmail.com
POLL_INTERVAL=30000
MARK_SEEN=true
SAVE_ATTACHMENTS=false
ATTACHMENTS_DIR=./attachments

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/openclaw-email-channel.log
DEBUG=false

# Advanced Settings
MAX_ATTACHMENT_SIZE=10485760  # 10MB in bytes
CONCURRENT_FETCHES=5
RECONNECT_DELAY=5000